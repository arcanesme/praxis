.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# Vale (downloaded by vale sync)
.vale-styles/

# Build artifacts from old project
__pycache__/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.venv/
